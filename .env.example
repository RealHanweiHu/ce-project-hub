# ── Required ─────────────────────────────────────────────────────────
# PostgreSQL connection string.
#   docker-compose:  postgres://postgres:cehub@db:5432/cehub
#   Aliyun RDS:      postgres://user:pass@pgm-xxxx.pg.rds.aliyuncs.com:5432/cehub
DATABASE_URL=postgres://postgres:cehub@db:5432/cehub

# Session signing secret, >= 32 random chars: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-32-plus-char-string

NODE_ENV=production

# ── Object storage (S3-compatible) ───────────────────────────────────
# docker-compose MinIO (default below), or Aliyun OSS:
#   S3_ENDPOINT=https://oss-cn-shenzhen-internal.aliyuncs.com  (internal endpoint when app is in the same region)
#   S3_REGION=oss-cn-shenzhen
#   S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=cehub
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
