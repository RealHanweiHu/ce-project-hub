# ── Required ─────────────────────────────────────────────────────────
# PostgreSQL connection string.
#   docker-compose:  postgres://postgres:cehub@db:5432/cehub
#   Aliyun RDS:      postgres://user:pass@pgm-xxxx.pg.rds.aliyuncs.com:5432/cehub
DATABASE_URL=postgres://postgres:cehub@db:5432/cehub
# 测试专用库（可选）：设置后 scripts/test.mjs 优先使用，避免全量测试污染开发库
# 注意：库名不要匹配 cehub_test*（该命名会触发钉钉外发硬抑制，令传输层测试失败）
# TEST_DATABASE_URL=postgres://postgres:cehub@localhost:55432/cehub_vitest

# Session signing secret, >= 32 random chars: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-32-plus-char-string

# HTTP port the app listens on (compose maps this). Default 3000.
PORT=3000

# ── Registration control ─────────────────────────────────────────────
# 是否开放自助注册。SAFE DEFAULT = false：新用户只能由管理员在后台创建，
# 或用下面的邀请码注册。设为 true 才开放公开注册。
ALLOW_REGISTRATION=false
# 注册邀请码：非空时自助注册必须提供匹配邀请码；留空且 ALLOW_REGISTRATION=true 则任何人可注册。
REGISTRATION_INVITE_CODE=

# ── Object storage (S3-compatible) ───────────────────────────────────
# docker-compose MinIO (default below), or Aliyun OSS:
#   S3_ENDPOINT=https://oss-cn-shenzhen-internal.aliyuncs.com  (internal endpoint when app is in the same region)
#   S3_REGION=oss-cn-shenzhen
#   S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=cehub
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ── App links / notifications ────────────────────────────────────────
# Public base URL used in notification links and DingTalk callback setup.
APP_BASE_URL=https://hub.example.com

# DingTalk notification delivery: `disabled` keeps site notifications only.
# Set `live` only for the production database. A cehub_test* database is a hard
# safety boundary and remains silent even if this variable is mistakenly `live`.
# Other non-production environments are silent unless explicitly set to `live`.
DINGTALK_DELIVERY_MODE=disabled

# Optional DingTalk robot fallback notifications.
NOTIFY_WEBHOOK_TYPE=dingtalk
NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_SECRET=

# ── DingTalk enterprise app ───────────────────────────────────────────
# Internal app credentials for calendar, work notices, and approval sync.
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_CORP_ID=
DINGTALK_AGENT_ID=

# Approval callback encryption settings. Generate real values locally:
#   token: openssl rand -hex 16
#   aes key: node -e "console.log(require('crypto').randomBytes(32).toString('base64').replace(/=/g,''))"
DINGTALK_CALLBACK_TOKEN=
DINGTALK_CALLBACK_AES_KEY=

# Native DingTalk interactive cards. When template/robot are absent, CE Hub
# automatically falls back to work-notice ActionCard links.
DINGTALK_INTERACTIVE_CARD_TEMPLATE_ID=
DINGTALK_INTERACTIVE_ROBOT_CODE=
# Phase B native button callbacks. Generate secret with:
#   openssl rand -base64 32
DINGTALK_INTERACTIVE_CARD_CALLBACK_ROUTE_KEY=cehub_action_card_v1
DINGTALK_INTERACTIVE_CARD_CALLBACK_SECRET=
DINGTALK_INTERACTIVE_CARD_ENABLED=true

# ── Misc / defaults (可留空使用默认) ─────────────────────────────────
# 自动化逾期扫描间隔（分钟），默认 30。
AUTOMATION_SCAN_INTERVAL_MIN=30

# ── docker-compose 变量（仅本机/自托管 db+minio 方案用到）──────────────
# 内置 Postgres 发布到宿主机的端口（生产建议不发布或加防火墙），默认 55432。
POSTGRES_PORT=55432
# 内置 Postgres / MinIO 的密码——生产务必改掉这些默认值。
POSTGRES_PASSWORD=cehub
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
